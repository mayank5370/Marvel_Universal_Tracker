generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id String @id @default(cuid())

  email String @unique

  passwordHash String

  role UserRole @default(USER)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("users")
}